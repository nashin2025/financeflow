// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  password      String?  // For email/password auth (optional, can use Supabase Auth instead)
  isPremium     Boolean  @default(false)
  isAdmin       Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  accounts      Account[]
  transactions  Transaction[]
  budgets       Budget[]
  goals         Goal[]
  categories    Category[]
}

model Account {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  type        String
  balance     Float    @default(0)
  currency    String   @default("MVR")
  color       String?
  icon        String?
  isActive    Boolean  @default(true)
  institution String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  transactions Transaction[]
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId   String?
  account     Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  type        String   // expense, income, transfer
  amount     Float
  currency    String   @default("MVR")
  description String?
  merchantName String?
  date        String
  time        String?
  note        String?
  isRecurring Boolean  @default(false)
  isExcluded  Boolean  @default(false)
  tags        String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Category {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  icon      String?
  color     String?
  type      String   // expense, income
  isSystem  Boolean  @default(false)
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  budgets      Budget[]
  transactions Transaction[]
}

model Budget {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId      String?
  category        Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  name            String
  amount          Float
  period          String   @default("monthly") // weekly, monthly, yearly
  startDate       String?
  rollover        Boolean  @default(false)
  alertThreshold  Int      @default(75)
  isActive        Boolean  @default(true)
  spent           Float    @default(0)
  remaining       Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Goal {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name              String
  type              String   // savings, debt_payoff, emergency_fund, purchase, investment
  targetAmount      Float
  currentAmount    Float    @default(0)
  targetDate       String
  icon              String?
  color             String?
  status            String   @default("active") // active, paused, completed
  monthlyContribution Float @default(0)
  completedAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt         DateTime @updatedAt
}